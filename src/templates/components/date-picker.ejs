<div class="card-editorial -mt-0 md:-mt-12 relative z-20">
    <h2 class="text-2xl font-black mb-8 text-center italic text-ink tracking-tight uppercase">Find Your Rental</h2>
    <form id="booking-form" class="space-y-6">
        <!-- Pickup Location -->
        <div>
            <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 ml-1 tracking-widest">Pickup Location</label>
            <div class="relative">
                <select name="pickup_location" class="w-full p-4 bg-paper rounded-xl border border-gray-100 text-sm font-black text-ink focus:ring-2 focus:ring-primary focus:border-transparent outline-none appearance-none cursor-pointer">
                    <% locations.forEach(loc => { %>
                        <option value="<%= loc.slug %>" <%= (typeof currentLoc !== 'undefined' && currentLoc === loc.slug) ? 'selected' : '' %>><%= loc.name %></option>
                    <% }) %>
                </select>
                <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"/></svg>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
                <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 ml-1 tracking-widest">Pickup Date</label>
                <input type="date" name="pickup_date" required class="w-full p-4 bg-paper rounded-xl border border-gray-100 text-sm font-black text-ink outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
            </div>
            <div>
                <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 ml-1 tracking-widest">Pickup Time</label>
                <input type="time" name="pickup_time" value="09:00" required class="w-full p-4 bg-paper rounded-xl border border-gray-100 text-sm font-black text-ink outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
                <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 ml-1 tracking-widest">Return Date</label>
                <input type="date" name="dropoff_date" required class="w-full p-4 bg-paper rounded-xl border border-gray-100 text-sm font-black text-ink outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
            </div>
            <div>
                <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 ml-1 tracking-widest">Return Time</label>
                <input type="time" name="dropoff_time" value="09:00" required class="w-full p-4 bg-paper rounded-xl border border-gray-100 text-sm font-black text-ink outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
            </div>
        </div>

        <div>
            <label class="block text-[10px] font-black uppercase text-gray-400 mb-2 ml-1 tracking-widest">Car Type</label>
            <div class="relative">
                <select name="car_type" class="w-full p-4 bg-paper rounded-xl border border-gray-100 text-sm font-black text-ink focus:ring-2 focus:ring-primary focus:border-transparent outline-none appearance-none cursor-pointer">
                    <option value="any">Any Car</option>
                    <option value="economy">Economy</option>
                    <option value="sedan">Sedan</option>
                    <option value="suv">SUV</option>
                    <option value="pickup">Pickup</option>
                </select>
                <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"/></svg>
                </div>
            </div>
        </div>

        <button type="submit" class="btn-primary w-full group mt-4">
            Find My Car
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </button>

        <p class="text-center text-[10px] text-gray-400 uppercase font-black tracking-tighter mt-4 opacity-60">
            No credit card required to browse • Insurance included
        </p>
    </form>
</div>
