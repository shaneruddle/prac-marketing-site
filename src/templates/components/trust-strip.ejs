                <span class="text-xs font-semibold text-gray-400 uppercase tracking-widest mt-1">In Pattaya</span>
            </div>
            <div class="flex flex-col items-center text-center">
                <span class="text-2xl font-bold text-ink"><%= site.trust.customers %></span>
                <span class="text-xs font-semibold text-gray-400 uppercase tracking-widest mt-1">Happy Drivers</span>
            </div>
            <div class="flex flex-col items-center text-center">
                <div class="flex items-center gap-1">
                    <span class="text-2xl font-bold text-ink"><%= site.trust.googleRating %></span>
