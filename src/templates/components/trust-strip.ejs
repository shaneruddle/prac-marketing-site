            </div>
            <div class="flex flex-col items-center text-center">
                <span class="text-lg font-bold text-ink mb-1">Free Delivery</span>
                <span class="text-xs font-semibold text-gray-400 uppercase tracking-widest leading-tight">To Your Hotel</span>
            </div>
        </div>
    </div>
</div>
