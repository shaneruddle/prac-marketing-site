<section id="enquire" class="bg-paper pb-32">
  <div class="max-w-7xl mx-auto px-6">
    <div class="dark-block">
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-primary/20 blur-[120px] rounded-full pointer-events-none"></div>
      <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-4xl md:text-5xl font-bold tracking-tighter mb-6">Get a Custom Quote</h2>
          <p class="text-white/60 text-lg leading-relaxed">Tell us how long you need a vehicle and we'll send our best long-term rate within a few hours. You can also reach us directly by phone or WhatsApp â we speak English and Russian.</p>
        </div>
        <form action="mailto:<%= site.contact.email %>" method="post" enctype="text/plain" class="space-y-5">
          <div>
            <label class="font-mono text-[10px] uppercase tracking-[0.2em] text-white/40 font-bold block mb-2">Name</label>
            <input type="text" name="Name" class="w-full bg-white/10 border-none rounded-2xl p-4 outline-none focus:bg-white/20 transition-all font-medium text-white placeholder-white/30">
          </div>
          <div>
            <label class="font-mono text-[10px] uppercase tracking-[0.2em] text-white/40 font-bold block mb-2">Email</label>
            <input type="email" name="Email" class="w-full bg-white/10 border-none rounded-2xl p-4 outline-none focus:bg-white/20 transition-all font-medium text-white placeholder-white/30">
          </div>
          <div>
            <label class="font-mono text-[10px] uppercase tracking-[0.2em] text-white/40 font-bold block mb-2">How long do you need a vehicle?</label>
            <textarea name="Details" rows="4" class="w-full bg-white/10 border-none rounded-2xl p-4 outline-none focus:bg-white/20 transition-all font-medium text-white placeholder-white/30 resize-none"></textarea>
          </div>
          <button type="submit" class="btn-primary w-full justify-center">Request Quote</button>
        </form>
      </div>
    </div>
  </div>
</section>
