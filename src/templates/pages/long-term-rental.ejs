<script>
(function () {
  const form = document.getElementById('lt-form');
  if (!form) return;

  form.addEventListener('submit', async function (e) {
    e.preventDefault();

    const honeypot = document.getElementById('lt-honeypot');
    if (honeypot && honeypot.value) return;

    const btn = document.getElementById('lt-submit');
    const msg = document.getElementById('lt-msg');

    btn.disabled = true;
    btn.textContent = 'Sending√¢¬Ä¬¶';

    const payload = {
      name: document.getElementById('lt-name').value.trim(),
      email: document.getElementById('lt-email').value.trim(),
      phone: document.getElementById('lt-phone').value.trim(),
      details: document.getElementById('lt-details').value.trim(),
      source: 'long-term-rental',
    };

    try {
      const res = await fetch('https://hook.eu2.make.com/vfhrd5l3kcumxewq3jxijt3dfq1apogb', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (res.ok) {
        msg.textContent = 'Thanks! We\'ll be in touch with your quote shortly.';
        msg.className = 'text-sm font-medium rounded-xl p-3 bg-green-500/20 text-green-300';
        msg.classList.remove('hidden');
        form.reset();
      } else {
        throw new Error('server error');
      }
    } catch {
      msg.textContent = 'Something went wrong. Please try again or contact us directly.';
      msg.className = 'text-sm font-medium rounded-xl p-3 bg-red-500/20 text-red-300';
      msg.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send Request';
    }
  });
})();
</script>
