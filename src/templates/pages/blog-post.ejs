<article class="pt-32 pb-24">
    <div class="container mx-auto px-4 max-w-3xl">
        <% if (post.category) { %>
        <span class="text-[10px] font-black uppercase tracking-widest text-primary"><%= post.category %></span>
        <% } %>
        <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight mt-3 mb-6 leading-tight"><%= post.title %></h1>
        <div class="flex items-center gap-3 text-[10px] font-black uppercase tracking-widest text-gray-400 mb-10">
            <span><%= new Date(post.publishedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) %></span>
            <% if (post.tags && post.tags.length) { %>
            <span class="w-1 h-1 bg-gray-300 rounded-full"></span>
            <span><%= post.tags.join(', ') %></span>
            <% } %>
        </div>
        <% if (post.coverImage) { %>
        <img src="<%= post.coverImage %>" alt="<%= post.title %>" class="w-full rounded-2xl mb-10 shadow-sm" />
        <% } %>
        <div class="blog-content"><%- post.content %></div>
        <% if (post.faqSchema) { %>
        <script type="application/ld+json"><%- post.faqSchema %></script>
        <% } %>

        <div class="mt-16 pt-10 border-t border-gray-100">
            <a href="/blog/" class="text-primary font-bold hover:underline inline-flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                Back to Blog
            </a>
        </div>
    </div>
</article>
