<section class="bg-gray-100 pt-32 pb-24">
    <div class="container mx-auto px-4 text-center">
        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4">About Pattaya Rent A Car</h1>
        <p class="text-xl text-gray-500 max-w-2xl mx-auto">Operating since 2016, we have built a reputation for trust, reliability, and the easiest car rental experience in Thailand.</p>
    </div>
</section>

<section class="py-24">
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="space-y-6">
                <h2 class="text-3xl font-bold text-gray-900 leading-tight">We aren't just a rental company, we are your travel partner in Pattaya.</h2>
                <p class="text-gray-600 leading-relaxed">
                    Our founder started the business with a single car and a mission: to remove the friction from renting a vehicle in Pattaya. Today, we have a diverse fleet of over 50 vehicles and a team of dedicated professionals serving thousands of tourists and expats every year.
                </p>
                <div class="grid grid-cols-2 gap-8 pt-8">
                    <div>
                        <span class="text-4xl font-extrabold text-orange-500 block mb-2"><%= site.trust.years %></span>
                        <span class="text-sm font-bold text-gray-400 uppercase tracking-widest">Experience</span>
                    </div>
                    <div>
                        <span class="text-4xl font-extrabold text-orange-500 block mb-2"><%= site.trust.customers %></span>
                        <span class="text-sm font-bold text-gray-400 uppercase tracking-widest">Served</span>
                    </div>
                </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div class="aspect-square bg-gray-100 rounded-3xl"></div>
                <div class="aspect-square bg-gray-50 rounded-3xl mt-12"></div>
            </div>
        </div>
    </div>
</section>
