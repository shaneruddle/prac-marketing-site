<section class="bg-paper pt-32 pb-20">
  <div class="max-w-7xl mx-auto px-6">
    <span class="eyebrow">Get in Touch</span>
    <h1 class="text-6xl md:text-8xl font-black tracking-tighter text-ink leading-[0.9]">Contact Us</h1>
    <p class="text-ink/60 text-lg leading-relaxed mt-8 max-w-2xl">We're here to help â reach us by phone, email, or pop into our office. Free delivery across Pattaya, seven days a week.</p>
  </div>
</section>

<section class="bg-paper pb-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

      <!-- Info cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">

        <!-- Location -->
        <div class="card-compact">
          <div class="icon-pill">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3 class="card-title-sm">Our Location</h3>
          <p class="card-body"><%= site.address %></p>
        </div>

        <!-- Phone -->
        <div class="card-compact">
          <div class="icon-pill">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <h3 class="card-title-sm">Phone</h3>
          <p class="card-body"><a href="tel:<%= site.contact.phone.replace(/\s/g, '') %>" class="hover:text-primary transition-colors"><%= site.contact.phone %></a></p>
        </div>

        <!-- Email -->
        <div class="card-compact">
          <div class="icon-pill">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <h3 class="card-title-sm">Email</h3>
          <p class="card-body"><a href="mailto:<%= site.contact.email %>" class="hover:text-primary transition-colors"><%= site.contact.email %></a></p>
        </div>

        <!-- Hours -->
        <div class="card-compact">
          <div class="icon-pill">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3 class="card-title-sm">Opening Hours</h3>
          <p class="card-body"><% if (site.openingHours && site.openingHours.Monday) { %>Open daily, <%= site.openingHours.Monday %><% } else { %>Open daily, 09:00 - 17:00<% } %></p>
        </div>

      </div><!-- /info cards -->

      <!-- Form panel -->
      <div class="card-compact">
        <h2 class="text-2xl font-bold tracking-tight text-ink mb-6">Send us a Message</h2>
        <form id="ct-form" class="space-y-5">
          <!-- Honeypot field — hidden from humans, bots fill it -->
          <input
            type="text"
            id="ct-honeypot"
            name="website"
            autocomplete="off"
            tabindex="-1"
            aria-hidden="true"
            style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;pointer-events:none;"
          />
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink/30 font-bold block mb-2">First Name</label>
              <input type="text" id="ct-firstname" name="First Name" required class="w-full bg-black/5 border-none rounded-2xl p-4 outline-none focus:bg-black/10 transition-all font-medium">
            </div>
            <div>
              <label class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink/30 font-bold block mb-2">Last Name</label>
              <input type="text" id="ct-lastname" name="Last Name" class="w-full bg-black/5 border-none rounded-2xl p-4 outline-none focus:bg-black/10 transition-all font-medium">
            </div>
          </div>
          <div>
            <label class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink/30 font-bold block mb-2">Email</label>
            <input type="email" id="ct-email" name="Email" required class="w-full bg-black/5 border-none rounded-2xl p-4 outline-none focus:bg-black/10 transition-all font-medium">
          </div>
          <div>
            <label class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink/30 font-bold block mb-2">Phone / WhatsApp</label>
            <input type="tel" id="ct-phone" name="Phone" placeholder="+66 81 234 5678"
              class="w-full bg-black/5 border-none rounded-2xl p-4 outline-none focus:bg-black/10 transition-all font-medium">
          </div>
          <div>
            <label class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink/30 font-bold block mb-2">Message</label>
            <textarea id="ct-message" name="Message" rows="5" required class="w-full bg-black/5 border-none rounded-2xl p-4 outline-none focus:bg-black/10 transition-all font-medium resize-none"></textarea>
          </div>
          <button type="submit" id="ct-submit" class="btn-primary w-full justify-center">Send Message</button>
        </form>
        <div id="ct-result" class="hidden"></div>
      </div><!-- /form panel -->

    </div>
  </div>
</section>

<% if (site.mapEmbedUrl) { %>
<section class="bg-paper pb-32">
  <div class="max-w-7xl mx-auto px-6">
    <div class="rounded-[32px] overflow-hidden shadow-xl shadow-black/5 h-[450px]">
      <iframe
        src="<%= site.mapEmbedUrl %>"
        width="100%" height="100%"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Pattaya Rent a Car location">
      </iframe>
    </div>
  </div>
</section>
<% } %>
