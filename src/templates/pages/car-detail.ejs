<section class="pt-32 pb-16">
    <div class="container mx-auto px-4">
        <div class="flex flex-wrap items-center gap-2 text-xs font-bold uppercase tracking-widest text-gray-400 mb-8">
            <a href="/" class="hover:text-orange-500">Home</a>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            <a href="/cars" class="hover:text-orange-500">Cars</a>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            <span class="text-gray-900"><%= car.name %></span>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 xl:gap-24">
            <!-- Left: Gallery -->
            <div class="space-y-4">
                <div class="aspect-video bg-gray-100 rounded-3xl flex items-center justify-center text-gray-400 font-medium overflow-hidden shadow-lg border border-gray-100">
                    Image: <%= car.name %> Exterior
                </div>
                <div class="grid grid-cols-3 gap-4">
                    <div class="aspect-square bg-gray-50 rounded-2xl flex items-center justify-center text-[10px] text-gray-300 border border-gray-100">Interior</div>
                    <div class="aspect-square bg-gray-50 rounded-2xl flex items-center justify-center text-[10px] text-gray-300 border border-gray-100">Boot Space</div>
                    <div class="aspect-square bg-gray-50 rounded-2xl flex items-center justify-center text-[10px] text-gray-300 border border-gray-100">Dashboard</div>
                </div>
            </div>

            <!-- Right: Details -->
            <div>
                <div class="flex justify-between items-start mb-6">
                    <div>
                        <span class="inline-block bg-blue-50 text-primary px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest mb-4"><%= car.type %></span>
                        <h1 class="text-4xl md:text-5xl font-black tracking-tight text-ink"><%= car.name %></h1>
                        <p class="text-lg text-gray-500 mt-4 leading-relaxed font-medium"><%= car.description %></p>
                    </div>
                </div>

                <div class="grid grid-cols-2 sm:grid-cols-3 gap-6 py-10 border-y border-gray-100 my-10">
                    <% [
                        { label: 'Seats', value: car.seats, icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z' },
                        { label: 'Gearbox', value: car.transmission, icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z' },
                        { label: 'Fuel', value: car.fuel, icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
                        { label: 'Luggage', value: car.luggage, icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z' },
                        { label: 'AC', value: car.ac, icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9' },
                        { label: 'Model Year', value: car.year, icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' }
                    ].forEach(spec => { %>
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 bg-gray-50 text-gray-400 rounded-lg flex items-center justify-center shrink-0">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= spec.icon %>"/></svg>
                            </div>
                            <div>
                                <span class="block text-[10px] font-black text-gray-400 uppercase tracking-widest"><%= spec.label %></span>
                                <span class="block text-sm font-black text-ink"><%= spec.value %></span>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <div class="bg-paper rounded-3xl p-8 border border-gray-100 mb-10">
                    <div class="flex items-center justify-between mb-8">
                        <div>
                            <span class="block text-xs font-black uppercase tracking-widest text-ink/30 mb-1">Status</span>
                            <div class="flex items-center gap-2">
                                <span class="w-2 h-2 bg-green-500 rounded-full"></span>
                                <span class="text-sm font-black text-ink uppercase tracking-widest">Available Now</span>
                            </div>
                        </div>
                        <div class="text-right">
                            <span class="block text-xs text-ink/40 font-medium italic">Instant confirmation</span>
                        </div>
                    </div>
                    
                    <a href="#booking-form" onclick="document.querySelector('#booking-form')?.scrollIntoView({ behavior: 'smooth' }); return false;" class="btn-primary w-full group">
                        <span>Check Dates & Book</span>
                        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                    </a>
                </div>

                <div class="flex flex-wrap gap-4">
                    <div class="flex items-center gap-2 text-sm text-gray-500">
                        <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        <span>Full Insurance</span>
                    </div>
                    <div class="flex items-center gap-2 text-sm text-gray-500">
                        <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        <span>24/7 Road Assistance</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<%- include('../components/trust-strip', { site }) %>
