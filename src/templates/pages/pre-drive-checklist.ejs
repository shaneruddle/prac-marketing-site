<%
const steps = [
  {
    title: 'Exterior damage walk',
    body: 'Do a full 360° lap of the car before you get in and <b style="color:#F07D17;font-weight:700">photograph any existing dents, scratches or scuffs</b>. Show them to the delivery driver so they\'re noted on your agreement.'
  },
  {
    title: 'Tyre condition',
    body: 'Check all four tyres plus the spare for sidewall bulges, nails and low pressure. <b style="color:#F07D17;font-weight:700">Flat or damaged? WhatsApp us before you drive.</b>'
  },
  {
    title: 'Windscreen & glass',
    body: 'Scan the windscreen and every window for chips, cracks and star fractures. <b style="color:#F07D17;font-weight:700">Sunlight at an angle reveals chips you can\'t see head-on.</b>'
  },
  {
    title: 'Lights check',
    body: 'Test headlights, indicators, hazards, brake and reverse lights. <b style="color:#F07D17;font-weight:700">Thai law requires every light to work when driving.</b>'
  },
  {
    title: 'Fuel level',
    body: 'Note the gauge reading and confirm the fuel type before the driver leaves. <b style="color:#F07D17;font-weight:700">Return it like-for-like — wrong fuel isn\'t covered by insurance.</b>'
  },
  {
    title: 'Seat & seatbelt',
    body: 'Adjust the seat for an easy reach to the pedals and wheel, then pull-test every belt. <b style="color:#F07D17;font-weight:700">Check the rear belts too if you have passengers.</b>'
  },
  {
    title: 'Mirror adjustment',
    body: 'Set both wing mirrors and the rear-view from your seated position. <b style="color:#F07D17;font-weight:700">Pattaya motorbikes filter fast — angle a little wider.</b>'
  },
  {
    title: 'Audio & air-con',
    body: 'Pair your phone to Bluetooth and get the air-con blowing cold before you roll. <b style="color:#F07D17;font-weight:700">Pattaya hits 36°C — run the AC from minute one.</b>'
  },
  {
    title: 'Navigation setup',
    body: 'Enter your first destination and mount your phone before moving off. <b style="color:#F07D17;font-weight:700">Never type while driving.</b>'
  },
  {
    title: 'Final sign-off',
    body: 'Confirm every check is done and agree the vehicle\'s condition with the delivery driver. <b style="color:#F07D17;font-weight:700">Your 24/7 WhatsApp support is active for the whole rental.</b>'
  }
];
%>

<!-- Hero + Video embed -->
<section class="bg-paper pt-32 pb-10">
  <div class="container mx-auto px-4 max-w-3xl">

    <span class="font-mono text-[12px] font-bold uppercase tracking-[0.28em] block mb-4" style="color:#F07D17">Before You Drive · Pattaya Rent a Car</span>

    <h1 class="font-black text-ink mb-5" style="font-size:clamp(32px,5vw,52px);letter-spacing:-0.025em;line-height:1.02">
      Your <em class="italic" style="color:#F07D17">pre-drive</em> checklist
    </h1>

    <p style="font-size:19px;color:rgba(29,29,27,.62);max-width:680px">
      Renting a car in Pattaya? Take ninety seconds before you drive away. These ten quick checks protect your deposit, keep your insurance simple, and get you on the road with total peace of mind.
    </p>

    <!-- Responsive 16:9 video embed -->
    <div style="position:relative;width:100%;padding-top:56.25%;margin-top:34px;margin-bottom:8px;border-radius:22px;overflow:hidden;box-shadow:0 30px 70px -30px rgba(29,29,27,.35);border:1px solid rgba(29,29,27,.10);background:#0a0a0a">
      <iframe
        src="/video/prac-pre-drive-check.html"
        title="Pattaya Rent a Car — Pre-Drive Checklist"
        loading="lazy"
        allowfullscreen
        style="position:absolute;inset:0;width:100%;height:100%;border:0"
      ></iframe>
    </div>
    <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-ink/40 mb-12">90-second guide · No sign-up · Works on mobile</p>

  </div>
</section>

<!-- 10-step written checklist (SEO payload) -->
<section class="bg-paper pb-16">
  <div class="container mx-auto px-4 max-w-3xl">

    <h2 class="text-3xl font-extrabold tracking-tight text-ink mb-6">The 10-point check, step by step</h2>

    <ol class="space-y-3 list-none m-0 p-0">
      <% steps.forEach(function(step, i) { %>
      <li style="display:flex;gap:18px;background:#fff;border:1px solid rgba(29,29,27,.10);border-radius:16px;padding:18px 22px;list-style:none;align-items:flex-start">
        <div style="font-size:14px;font-weight:800;color:#fff;background:#1D1D1B;min-width:42px;height:42px;border-radius:999px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
          <%= i < 9 ? '0' + (i + 1) : (i + 1) %>
        </div>
        <div>
          <h3 style="font-weight:800;font-size:18px;letter-spacing:-0.01em;margin:0 0 3px;color:#1D1D1B"><%= step.title %></h3>
          <p style="font-size:15px;color:rgba(29,29,27,.62);margin:0;line-height:1.6"><%- step.body %></p>
        </div>
      </li>
      <% }); %>
    </ol>

  </div>
</section>

<!-- CTA block -->
<section class="bg-paper pb-24">
  <div class="container mx-auto px-4 max-w-3xl">
    <div class="bg-ink rounded-3xl px-8 py-9 md:px-10 flex flex-wrap items-center justify-between gap-5">
      <h2 class="text-3xl font-extrabold text-white tracking-tight m-0">
        Ready to <em class="italic" style="color:#F07D17">explore Pattaya?</em>
      </h2>
      <a href="<%= langPrefix %>/" class="font-mono font-bold text-[13px] uppercase tracking-[0.12em] text-white px-7 py-4 rounded-full whitespace-nowrap transition-colors inline-block" style="background:#F07D17">
        Search Available Cars
      </a>
    </div>
  </div>
</section>
