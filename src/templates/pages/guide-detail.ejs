<section class="pt-32 pb-16">
    <div class="container mx-auto px-4">
        <div class="flex flex-wrap items-center gap-2 text-xs font-bold uppercase tracking-widest text-gray-400 mb-8">
            <a href="/" class="hover:text-orange-500">Home</a>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            <a href="/cars" class="hover:text-orange-500">Cars</a>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            <span class="text-gray-900"><%= guide.title %></span>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 xl:gap-24">
            <!-- Left: Gallery -->
            <div class="space-y-4">
                <div class="aspect-video bg-gray-100 rounded-3xl overflow-hidden shadow-lg border border-gray-100">
                    <% if (guide.heroImage) { %>
                        <img src="<%= guide.heroImage %>" alt="<%= guide.title %>" class="w-full h-full object-cover">
                    <% } else { %>
                        <div class="w-full h-full flex items-center justify-center text-gray-400 font-medium">No image available</div>
                    <% } %>
                </div>
                <% if (guide.gallery && guide.gallery.length > 0) { %>
                <div class="grid grid-cols-3 gap-4">
                    <% guide.gallery.slice(0,3).forEach(function(img) { %>
                        <div class="aspect-square rounded-2xl overflow-hidden border border-gray-100">
                            <img src="<%= img %>" alt="<%= guide.title %>" class="w-full h-full object-cover">
                        </div>
                    <% }) %>
                </div>
                <% } else { %>
                <div class="grid grid-cols-3 gap-4">
                    <div class="aspect-square bg-gray-50 rounded-2xl flex items-center justify-center text-[10px] text-gray-300 border border-gray-100">Interior</div>
                    <div class="aspect-square bg-gray-50 rounded-2xl flex items-center justify-center text-[10px] text-gray-300 border border-gray-100">Boot Space</div>
                    <div class="aspect-square bg-gray-50 rounded-2xl flex items-center justify-center text-[10px] text-gray-300 border border-gray-100">Dashboard</div>
                </div>
                <% } %>
            </div>

            <!-- Right: Details -->
            <div>
                <div class="flex justify-between items-start mb-6">
                    <div>
                        <span class="inline-block bg-blue-50 text-primary px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest mb-4"><%= guide.category %></span>
                        <% if (guide.alternativeRationale) { %>
                            <p class="text-sm text-gray-400 italic mb-2"><%= guide.alternativeRationale %></p>
                        <% } %>
                        <h1 class="text-4xl md:text-5xl font-black tracking-tighter text-ink leading-[0.9]"><%= guide.h1 || guide.title %></h1>
                        <p class="text-lg text-gray-500 mt-4 leading-relaxed font-medium"><%= guide.intro %></p>
                    </div>
                </div>

                <div class="grid grid-cols-2 sm:grid-cols-3 gap-6 py-10 border-y border-gray-100 my-10">
                    <% [
                        { label: 'Seats', value: guide.seats, icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z' },
                        { label: 'Gearbox', value: guide.transmission, icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z' },
                        { label: 'Fuel', value: guide.fuelType, icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
                        { label: 'Luggage', value: guide.luggage, icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z' },
                        { label: 'Model Year', value: guide.year, icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' }
                    ].forEach(spec => { %>
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 bg-gray-50 text-gray-400 rounded-lg flex items-center justify-center shrink-0">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= spec.icon %>"/></svg>
                            </div>
                            <div>
                                <span class="block text-[10px] font-black text-gray-400 uppercase tracking-widest"><%= spec.label %></span>
                                <span class="block text-sm font-black text-ink"><%= spec.value %></span>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <% if (guide.typicalPerDay) { %>
<div class="bg-orange-50 border border-orange-100 rounded-2xl px-6 py-5 my-8">
  <p class="text-[10px] font-black text-orange-400 uppercase tracking-widest mb-1">Typical Price</p>
  <div class="flex items-baseline gap-2">
    <span class="text-3xl font-black text-ink">&#3647;<%= guide.typicalPerDay.toLocaleString() %></span>
    <span class="text-sm font-bold text-gray-400">&nbsp;/ day</span>
  </div>
  <p class="text-xs text-gray-400 mt-1">Based on a <%= guide.typicalDays %>-day rental &middot; prices vary by season &amp; availability</p>
</div>
<% } %>
<div class="flex items-center justify-between mb-4">
                    <div class="flex items-center gap-2">
                        <span class="w-2 h-2 bg-green-500 rounded-full"></span>
                        <span class="text-sm font-black text-ink uppercase tracking-widest">Available Now</span>
                    </div>
                    <span class="text-xs text-ink/40 font-medium italic">Instant confirmation</span>
                </div>
                <%- include('../components/date-picker') %>

                <div class="flex flex-wrap gap-4">
                    <div class="flex items-center gap-2 text-sm text-gray-500">
                        <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        <span>Full Insurance</span>
                    </div>
                    <div class="flex items-center gap-2 text-sm text-gray-500">
                        <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        <span>24/7 Road Assistance</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<% if (guide.featuredCars && guide.featuredCars.length > 0) { %>
<section class="py-16 bg-paper border-t border-gray-100">
    <div class="container mx-auto px-4">
        <h2 class="text-2xl font-black text-ink mb-2">Book This Instead</h2>
        <p class="text-gray-500 mb-8">These vehicles are available to book right now.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            <% guide.featuredCars.forEach(function(car) { %>
                <div class="bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm">
                    <div class="aspect-[4/3] bg-gray-50 overflow-hidden">
                        <% if (car.mainImage) { %>
                            <img src="<%= car.mainImage %>" alt="<%= car.name %>" class="w-full h-full object-cover">
                        <% } else { %>
                            <div class="w-full h-full flex items-center justify-center text-[10px] text-gray-300 uppercase font-black tracking-widest">No Image</div>
                        <% } %>
                    </div>
                    <div class="p-6">
                        <h3 class="font-black text-ink text-lg mb-4"><%= car.name %></h3>
                        <a href="https://app.pattayarentacar.com" class="btn-primary w-full text-xs py-3 flex items-center justify-center gap-2 group">
                            Check Availability
                            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                        </a>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</section>
<% } %>

<%- include('../components/trust-strip', { site }) %>
