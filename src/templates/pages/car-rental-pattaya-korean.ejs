<!-- Hero -->
<section class="bg-paper pt-32 pb-24 border-b border-gray-100">
    <div class="container mx-auto px-6">
        <div class="mb-4 inline-flex items-center gap-2 px-3 py-1 bg-blue-50 text-primary rounded-full text-[10px] font-black uppercase tracking-widest border border-blue-100">
            파타야 렌터카
        </div>
        <h1 class="text-4xl md:text-6xl font-light tracking-tight mb-6 text-ink">파타야 <span class="font-black italic text-primary">렌터카</span></h1>
        <p class="text-xl text-gray-500 max-w-2xl font-medium">파타야 렌터카 서비스 — 호텔 또는 콘도까지 직접 배달해 드립니다. ฿590/일부터 시작하며, 숨겨진 비용 없이 완전 보험이 포함됩니다. 파타야 자동차 렌트, 파타야 렌트카 모두 저희가 도와드립니다.</p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
            <a href="/#booking" class="btn-primary inline-flex">지금 예약하기</a>
            <a href="https://wa.me/<%= site.contact.whatsapp %>" class="inline-flex items-center justify-center gap-3 bg-white border-2 border-gray-200 hover:border-primary text-ink font-black uppercase tracking-widest py-4 px-8 rounded-full transition-all active:scale-95">WhatsApp 문의</a>
        </div>
    </div>
</section>

<!-- Main Content -->
<section class="py-24">
    <div class="container mx-auto px-6">
        <div class="max-w-3xl mx-auto space-y-20">

            <!-- 신뢰 신호 -->
            <div>
                <h2 class="text-3xl font-black text-ink mb-6">왜 저희와 함께 렌트하시나요?</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <div class="flex gap-4 items-start">
                        <div class="w-10 h-10 bg-blue-50 text-primary rounded-full flex items-center justify-center shrink-0">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        </div>
                        <div>
                            <p class="font-black text-ink text-sm mb-1">호텔 픽업 서비스</p>
                            <p class="text-gray-500 text-sm leading-relaxed">파타야 전 지역 호텔 및 콘도로 무료 배달해 드립니다.</p>
                        </div>
                    </div>
                    <div class="flex gap-4 items-start">
                        <div class="w-10 h-10 bg-blue-50 text-primary rounded-full flex items-center justify-center shrink-0">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        </div>
                        <div>
                            <p class="font-black text-ink text-sm mb-1">무료 취소</p>
                            <p class="text-gray-500 text-sm leading-relaxed">예약 변경이나 취소가 필요하시면 언제든지 연락 주세요.</p>
                        </div>
                    </div>
                    <div class="flex gap-4 items-start">
                        <div class="w-10 h-10 bg-blue-50 text-primary rounded-full flex items-center justify-center shrink-0">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                        </div>
                        <div>
                            <p class="font-black text-ink text-sm mb-1">영어/한국어 지원</p>
                            <p class="text-gray-500 text-sm leading-relaxed">영어로 편리하게 소통 가능하며 한국어 안내도 지원합니다.</p>
                        </div>
                    </div>
                    <div class="flex gap-4 items-start">
                        <div class="w-10 h-10 bg-blue-50 text-primary rounded-full flex items-center justify-center shrink-0">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                        </div>
                        <div>
                            <p class="font-black text-ink text-sm mb-1">완전 보험 포함</p>
                            <p class="text-gray-500 text-sm leading-relaxed">태국 최고의 보험사 Viriyah Insurance의 1종 완전 보험이 포함됩니다.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 차량 종류 -->
            <div>
                <h2 class="text-3xl font-black text-ink mb-6">차량 종류 및 가격</h2>
                <p class="text-gray-500 leading-relaxed mb-6">
                    경제형 소형차부터 넓은 SUV, 픽업트럭까지 100대 이상의 차량을 보유하고 있습니다. 모든 차량은 에어컨이 완비되어 있으며 정기적으로 점검됩니다. Honda PCX 150, Honda Click 등 오토바이 렌트도 가능합니다.
                </p>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm border-collapse">
                        <thead>
                            <tr class="bg-gray-100">
                                <th class="text-left p-3 font-black text-ink border-b border-gray-200">차종</th>
                                <th class="text-left p-3 font-black text-ink border-b border-gray-200">예시 차량</th>
                                <th class="text-left p-3 font-black text-ink border-b border-gray-200">하루 가격 (THB)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="border-b border-gray-100">
                                <td class="p-3 text-gray-600 font-medium">경제형</td>
                                <td class="p-3 text-gray-600">Honda Jazz, Toyota Yaris</td>
                                <td class="p-3 text-gray-600">฿590부터</td>
                            </tr>
                            <tr class="border-b border-gray-100">
                                <td class="p-3 text-gray-600 font-medium">세단</td>
                                <td class="p-3 text-gray-600">Toyota Vios, Honda City</td>
                                <td class="p-3 text-gray-600">฿790부터</td>
                            </tr>
                            <tr class="border-b border-gray-100">
                                <td class="p-3 text-gray-600 font-medium">SUV</td>
                                <td class="p-3 text-gray-600">Honda HR-V, Toyota Fortuner</td>
                                <td class="p-3 text-gray-600">฿1,200부터</td>
                            </tr>
                            <tr>
                                <td class="p-3 text-gray-600 font-medium">픽업트럭</td>
                                <td class="p-3 text-gray-600">Toyota Revo, MG Extender</td>
                                <td class="p-3 text-gray-600">฿1,500부터</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <p class="text-xs text-gray-400 mt-3 leading-relaxed">
                    가격은 최소 3일 렌트 기준이며 시즌에 따라 변동될 수 있습니다. 정확한 가격은 WhatsApp으로 문의해 주세요.
                </p>
            </div>

            <!-- 필요 서류 -->
            <div>
                <h2 class="text-3xl font-black text-ink mb-6">필요 서류</h2>
                <ul class="space-y-3 mb-4">
                    <li class="flex gap-3 items-start">
                        <div class="w-5 h-5 bg-blue-50 text-primary rounded-full flex items-center justify-center shrink-0 mt-0.5">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <span class="text-gray-500">여권 (유효한 것)</span>
                    </li>
                    <li class="flex gap-3 items-start">
                        <div class="w-5 h-5 bg-blue-50 text-primary rounded-full flex items-center justify-center shrink-0 mt-0.5">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <span class="text-gray-500">한국 운전면허증 + 국제운전면허증 (IDP)</span>
                    </li>
                    <li class="flex gap-3 items-start">
                        <div class="w-5 h-5 bg-blue-50 text-primary rounded-full flex items-center justify-center shrink-0 mt-0.5">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <span class="text-gray-500">보증금 현금 또는 계좌이체 (THB 5,000)</span>
                    </li>
                </ul>
                <p class="text-gray-500 leading-relaxed">
                    <strong class="text-ink">중요:</strong> 한국 국적 방문객은 태국에서 운전하기 위해 <strong>국제운전면허증(IDP)</strong>이 반드시 필요합니다. 국제운전면허증은 한국 출발 전에 도로교통공단(TS)에서 발급받아야 하며, 태국 현지에서는 발급이 불가능합니다. 한국 운전면허증만으로는 법적으로 운전이 인정되지 않습니다.
                </p>
            </div>

            <!-- 호텔 배달 서비스 -->
            <div>
                <h2 class="text-3xl font-black text-ink mb-6">호텔 배달 서비스</h2>
                <p class="text-gray-500 leading-relaxed mb-4">
                    파타야 해변, 좀티엔, 나클루아, 프라툼낙 등 파타야 전 지역의 호텔 및 콘도로 무료 배달해 드립니다. 별도의 픽업 장소로 이동하실 필요가 없습니다.
                </p>
                <p class="text-gray-500 leading-relaxed mb-4">
                    렌트 기간이 끝나면 저희가 직접 차량을 회수하러 찾아갑니다. WhatsApp으로 정확한 주소만 알려주시면 약속된 시간에 도착합니다.
                </p>
                <p class="text-gray-500 leading-relaxed">
                    우타파오 공항(U-Tapao) 및 수완나품 공항(Suvarnabhumi)으로의 배달도 가능합니다. 사전에 문의해 주세요.
                </p>
            </div>

            <!-- 예약 방법 -->
            <div>
                <h2 class="text-3xl font-black text-ink mb-6">예약 방법</h2>
                <ol class="space-y-4 mb-8">
                    <li class="flex gap-4 items-start">
                        <span class="w-8 h-8 bg-primary text-white rounded-full flex items-center justify-center shrink-0 font-black text-sm">1</span>
                        <span class="text-gray-500 pt-1">차량 선택 — 원하시는 차종과 렌트 기간을 선택하세요.</span>
                    </li>
                    <li class="flex gap-4 items-start">
                        <span class="w-8 h-8 bg-primary text-white rounded-full flex items-center justify-center shrink-0 font-black text-sm">2</span>
                        <span class="text-gray-500 pt-1">날짜 확인 — 예약 양식을 작성하시거나 WhatsApp으로 직접 문의해 주세요.</span>
                    </li>
                    <li class="flex gap-4 items-start">
                        <span class="w-8 h-8 bg-primary text-white rounded-full flex items-center justify-center shrink-0 font-black text-sm">3</span>
                        <span class="text-gray-500 pt-1">호텔 주소 입력 — 배달 주소와 시간을 알려주시면 확인 후 차량을 준비합니다.</span>
                    </li>
                </ol>
                <div class="flex flex-col sm:flex-row gap-4">
                    <a href="/#booking" class="btn-primary inline-flex">지금 예약하기</a>
                    <a href="https://wa.me/<%= site.contact.whatsapp %>" class="inline-flex items-center justify-center gap-3 bg-white border-2 border-gray-200 hover:border-primary text-ink font-black uppercase tracking-widest py-4 px-8 rounded-full transition-all active:scale-95">WhatsApp 문의</a>
                </div>
            </div>

            <!-- 오토바이 렌트 크로스링크 -->
            <div>
                <h2 class="text-3xl font-black text-ink mb-6">파타야 오토바이 렌트</h2>
                <p class="text-gray-500 leading-relaxed mb-4">
                    자동차보다 가볍게 이동하고 싶으시다면 오토바이나 스쿠터가 파타야의 해변 도로와 좁은 골목길을 다니기에 훨씬 편리합니다. 어디서나 주차할 수 있고, 교통 체증을 피해 빠르게 이동할 수 있습니다.
                </p>
                <p class="text-gray-500 leading-relaxed">
                    오토바이 렌트도 찾고 계신가요? Honda Click, Honda PCX 150, Yamaha NMAX 등 다양한 모델을 제공합니다. <a href="https://www.pattayarentabike.com" target="_blank" rel="noopener" class="text-primary font-bold hover:underline">파타야 오토바이 렌트 보기 →</a>
                </p>
            </div>

        </div>
    </div>
</section>

<!-- CTA Block -->
<section class="py-24 bg-ink">
    <div class="container mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-5xl font-black text-white italic tracking-tight mb-4">파타야 렌터카를 예약하실 준비가 되셨나요?</h2>
        <p class="text-white/40 font-medium mb-10 max-w-lg mx-auto">주 7일 호텔 또는 콘도까지 배달해 드립니다. 온라인으로 차량을 선택하시거나 WhatsApp으로 문의해 주세요.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/#booking" class="btn-primary inline-flex">지금 예약하기</a>
            <a href="https://wa.me/<%= site.contact.whatsapp %>" class="inline-flex items-center justify-center gap-3 bg-white/10 hover:bg-white/20 border border-white/20 text-white font-black uppercase tracking-widest py-4 px-8 rounded-full transition-all active:scale-95">WhatsApp 문의</a>
        </div>
    </div>
</section>
