<section class="bg-gray-100 pt-32 pb-24">
    <div class="container mx-auto px-4 text-center">
        <h1 class="text-4xl md:text-5xl font-black tracking-tighter leading-[0.9] mb-4">Blog</h1>
        <p class="text-xl text-gray-500">Tips, guides, and news for renting in Pattaya.</p>
    </div>
</section>

<section class="py-24">
    <div class="container mx-auto px-4">
        <% if (posts && posts.length > 0) { %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% posts.forEach(post => { %>
            <a href="/blog/<%= post.slug %>/" class="group bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 flex flex-col hover:-translate-y-1 transition-all">
                <div class="aspect-[16/9] bg-gray-200 overflow-hidden">
                    <% if (post.coverImage) { %>
                    <img src="<%= post.coverImage %>" alt="<%= post.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform" loading="lazy" />
                    <% } %>
                </div>
                <div class="p-6 flex flex-col flex-1">
                    <% if (post.category) { %>
                    <span class="text-[10px] font-black uppercase tracking-widest text-primary mb-2"><%= post.category %></span>
                    <% } %>
                    <h2 class="text-lg font-bold text-ink mb-2 group-hover:text-primary transition-colors leading-snug"><%= post.title %></h2>
                    <p class="text-gray-500 text-sm leading-relaxed mb-4 flex-1"><%= post.excerpt %></p>
                    <span class="text-[10px] font-black uppercase tracking-widest text-gray-400">
                        <%= new Date(post.publishedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                    </span>
                </div>
            </a>
            <% }) %>
        </div>

        <% if (totalPages > 1) { %>
        <nav class="flex items-center justify-center gap-2 mt-16">
            <% const prevHref = currentPage === 2 ? '/blog/' : '/blog/page/' + (currentPage - 1) + '/'; %>
            <% if (currentPage > 1) { %>
            <a href="<%= prevHref %>" class="px-4 py-2 rounded-xl border border-gray-100 text-xs font-black uppercase tracking-widest hover:border-gray-300 transition-colors">Prev</a>
            <% } %>
            <% for (let i = 1; i <= totalPages; i++) { %>
                <% const href = i === 1 ? '/blog/' : '/blog/page/' + i + '/'; %>
                <% if (i === currentPage) { %>
                <span class="w-10 h-10 flex items-center justify-center rounded-xl bg-primary text-white text-sm font-black"><%= i %></span>
                <% } else { %>
                <a href="<%= href %>" class="w-10 h-10 flex items-center justify-center rounded-xl border border-gray-100 text-sm font-bold hover:border-gray-300 transition-colors"><%= i %></a>
                <% } %>
            <% } %>
            <% if (currentPage < totalPages) { %>
            <a href="/blog/page/<%= currentPage + 1 %>/" class="px-4 py-2 rounded-xl border border-gray-100 text-xs font-black uppercase tracking-widest hover:border-gray-300 transition-colors">Next</a>
            <% } %>
        </nav>
        <% } %>

        <% } else { %>
        <p class="text-center text-gray-500">No blog posts yet. Check back soon.</p>
        <% } %>
    </div>
</section>
