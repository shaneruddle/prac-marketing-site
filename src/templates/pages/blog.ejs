<section class="bg-gray-50 pt-32 pb-24">
    <div class="container mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4">Travel Blog</h1>
        <p class="text-xl text-gray-500 max-w-2xl">Tips, guides, and inspiration for your next road trip in and around Pattaya.</p>
    </div>
</section>

<section class="py-24">
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
            <% [
                { title: 'Best Time to Rent a Car in Pattaya', date: 'May 15, 2024', cat: 'Guides' },
                { title: 'Driving from Pattaya to Bangkok: Complete Guide', date: 'Apr 28, 2024', cat: 'Tips' },
                { title: '10 Must-Visit Places Near Pattaya by Car', date: 'Mar 12, 2024', cat: 'Destinations' }
            ].forEach(post => { %>
                <article class="group">
                    <div class="aspect-video bg-gray-100 rounded-3xl mb-6 overflow-hidden border border-gray-100">
                        <!-- Post Image Placeholder -->
                        <div class="w-full h-full flex items-center justify-center text-gray-300 font-bold uppercase tracking-widest text-xs">Article Image</div>
                    </div>
                    <div class="flex items-center gap-4 text-[10px] font-bold uppercase tracking-widest text-orange-500 mb-3">
                        <span><%= post.cat %></span>
                        <span class="text-gray-300">•</span>
                        <span class="text-gray-400 font-medium"><%= post.date %></span>
                    </div>
                    <h2 class="text-2xl font-bold text-gray-900 group-hover:text-orange-500 transition-colors mb-4 leading-tight">
                        <a href="/blog/post-placeholder"><%= post.title %></a>
                    </h2>
                    <p class="text-gray-500 text-sm leading-relaxed mb-6 line-clamp-3">
                        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation...
                    </p>
                    <a href="/blog/post-placeholder" class="text-sm font-bold text-gray-900 hover:underline">Read More</a>
                </article>
            <% }) %>
        </div>
    </div>
</section>
