<section class="bg-gray-100 pt-32 pb-24">
    <div class="container mx-auto px-4 text-center">
        <h1 class="text-4xl md:text-5xl font-black tracking-tighter leading-[0.9] mb-4">Frequently Asked Questions</h1>
        <p class="text-xl text-gray-500">Everything you need to know about renting a car in Pattaya.</p>
    </div>
</section>

<section class="py-24">
    <div class="container mx-auto px-4 max-w-3xl">
        <%
        const grouped = {};
        (faqs || []).forEach(f => {
            const cat = f.category || 'General';
            if (!grouped[cat]) grouped[cat] = [];
            grouped[cat].push(f);
        });
        const categories = Object.keys(grouped);
        %>
        <% if (categories.length > 0) { %>
            <% categories.forEach(cat => { %>
            <div class="mb-12">
                <h2 class="text-2xl font-bold tracking-tighter mb-6 pb-2 border-b border-gray-100"><%= cat %></h2>
                <div class="space-y-4">
                    <% grouped[cat].forEach(item => { %>
                    <div class="faq-item bg-white rounded-2xl border border-gray-100 overflow-hidden">
                        <button type="button" class="faq-trigger w-full flex items-center justify-between gap-4 p-6 text-left">
                            <span class="font-bold text-ink"><%= item.q %></span>
                            <svg class="faq-chevron w-5 h-5 text-primary shrink-0 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"/></svg>
                        </button>
                        <div class="faq-answer hidden px-6 pb-6 text-gray-500 leading-relaxed"><%= item.a %></div>
                    </div>
                    <% }) %>
                </div>
            </div>
            <% }) %>
        <% } else { %>
        <p class="text-center text-gray-500">FAQs coming soon.</p>
        <% } %>
    </div>
</section>
