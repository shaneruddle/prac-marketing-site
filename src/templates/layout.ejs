<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | <%= site.name %></title>
    <meta name="description" content="<%= description %>">
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
    
    <!-- Open Graph -->
    <meta property="og:title" content="<%= title %> | <%= site.name %>">
    <meta property="og:description" content="<%= description %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://<%= site.domain %><%= url %>">
    <meta property="og:image" content="https://<%= site.domain %>/assets/images/og-image.jpg">
    
    <!-- Canonical & Hreflang -->
    <link rel="canonical" href="https://<%= site.domain %><%= url %>">
    <% languages.forEach(l => { %>
        <link rel="alternate" hreflang="<%= l.code %>" href="https://<%= site.domain %><%= l.path %><%= url.replace(/^\/[a-z]{2}\//, '') %>">
    <% }) %>

    <!-- Styling -->
    <link rel="stylesheet" href="/assets/css/main.css">
    <link rel="icon" type="image/jpeg" href="https://firebasestorage.googleapis.com/v0/b/pattaya-rent-a-car-rebuild.firebasestorage.app/o/PRAC-Icon.jpg?alt=media&token=f5935b90-df97-4241-bb73-149a8ea1b939">

    <!-- Structured Data -->
    <script type="application/ld+json">
        <%- JSON.stringify(schema) %>
    </script>
</head>
<body class="font-sans text-ink bg-paper antialiased">
    
    <%- include('components/header', { site, languages, lang, url }) %>

    <main id="main-content">
        <%- body %>
    </main>

    <%- include('components/footer', { site, lang }) %>

    <!-- Floating Contact Buttons -->
    <%- include('components/floating-contact', { site }) %>

    <%- include('components/date-picker-overlay') %>

    <!-- Mobile Menu — portalled to body root so fixed inset-0 resolves to viewport (not header's backdrop-filter containing block) -->
    <div id="mobile-menu" class="fixed inset-0 bg-ink z-50 translate-x-full transition-transform duration-300 md:hidden flex flex-col items-center justify-center p-10">
    <button id="mobile-menu-close" aria-label="Close menu" class="absolute top-6 right-6 p-2 text-white/60 hover:text-white transition-colors">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
        <nav class="flex flex-col items-center gap-10 text-center">
            <% [
                { name: 'Our Fleet', path: '/cars' },
                { name: 'Locations', path: '/locations' },
                { name: 'Long Term', path: '/long-term-rental' },
                { name: 'FAQ', path: '/faq' },
                { name: 'About', path: '/about' },
                { name: 'Contact', path: '/contact' }
            ].forEach(link => { %>
                <a href="<%= lang === 'en' ? link.path : '/' + lang + link.path %>" class="text-3xl font-black italic text-white uppercase tracking-tighter hover:text-primary transition-colors">
                    <%= link.name %>
                </a>
            <% }) %>

            <a href="https://pattayarentabike.com/" rel="noopener" class="text-3xl font-black italic text-white uppercase tracking-tighter hover:text-primary transition-colors">Rent a Bike</a>

            <% /* EN-only launch: mobile language switcher disabled — remove wrapping if/end to re-enable */ if (false) { %>
<div class="h-px w-20 bg-white/10 my-4"></div>

            <div class="flex gap-4">
                <% languages.forEach(l => { %>
                    <a href="<%= l.path %><%= url.replace(/^\/[a-z]{2}\//, '') %>" class="text-xl <%= l.code === lang ? 'grayscale-0' : 'grayscale' %>">
                        <%= l.flag %>
                    </a>
                <% }) %>
            </div>
<% } /* end disabled mobile language switcher */ %>

            <a href="tel:<%= site.contact.phone.replace(/\s/g, '') %>" class="text-2xl font-black text-primary uppercase tracking-widest mt-4">
                <%= site.contact.phone %>
            </a>
        </nav>
    </div>
    <script src="/assets/js/main.js" defer></script>
</body>
</html>
